# Full-stack production Dockerfile
FROM node:18-alpine AS frontend-build

WORKDIR /app/frontend
COPY frontend/package*.json ./
RUN npm ci --only=production

COPY frontend/ ./
RUN npm run build

# Backend stage
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    bash \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY Backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy backend code
COPY Backend/ ./Backend/

# Copy built frontend
COPY --from=frontend-build /app/frontend/out ./frontend/out

# Set PYTHONPATH
ENV PYTHONPATH=/app/Backend

# Expose port
EXPOSE 8000

# Create startup script
RUN echo '#!/bin/bash' > start.sh && \
    echo 'set -e' >> start.sh && \
    echo 'PORT=${PORT:-8000}' >> start.sh && \
    echo 'echo "Starting SME Costing Copilot on port $PORT"' >> start.sh && \
    echo 'export PYTHONPATH=/app/Backend:$PYTHONPATH' >> start.sh && \
    echo 'export DATABASE_URL=${DATABASE_URL:-"sqlite:///app.db"}' >> start.sh && \
    echo 'cd /app/Backend' >> start.sh && \
    echo 'python -m uvicorn app.main:app --host 0.0.0.0 --port $PORT' >> start.sh && \
    chmod +x start.sh

# Health check
HEALTHCHECK --interval=30s --timeout=30s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:${PORT:-8000}/health || exit 1

# Start the application
CMD ["./start.sh"]
