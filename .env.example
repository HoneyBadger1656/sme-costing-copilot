# Production Environment Variables Template
# Copy this to .env and fill in your values

# Database Configuration
DATABASE_URL=postgresql://postgres:password@postgres.railway.app:5432/railway

# JWT Configuration (CRITICAL: Use a strong secret key in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Configuration
# Get Groq API key free at: https://console.groq.com/keys
# Add GROQ_API_KEY=your_key_here to your .env file
# Or use OpenAI: OPENAI_API_KEY=your_key_here

# Application Configuration
DEBUG=false
ENVIRONMENT=production
LOG_LEVEL=INFO

# Frontend Configuration
NEXT_PUBLIC_API_URL=https://your-app-name.railway.app
PUBLIC_URL=https://your-app-name.railway.app

# Security Configuration (CRITICAL: Set proper CORS origins in production)
CORS_ORIGINS=https://your-app-name.railway.app,https://www.your-app-name.railway.app

# Redis Configuration (for caching and background tasks)
REDIS_URL=redis://localhost:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Phase 3: Email Notification Configuration
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=your-sendgrid-api-key-here
EMAIL_FROM_ADDRESS=noreply@your-domain.com
EMAIL_FROM_NAME=SME Costing Copilot

# Phase 3: Report Generation Configuration
REPORT_STORAGE_PATH=./reports
MAX_REPORT_SIZE_MB=50
CONCURRENT_REPORT_LIMIT=5

# Phase 3: Audit Log Configuration
AUDIT_LOG_RETENTION_DAYS=365

# Phase 3: Rate Limiting Configuration
RATE_LIMIT_REPORTS_PER_HOUR=10
RATE_LIMIT_EMAILS_PER_HOUR=50

# Railway Configuration (auto-set by Railway)
PORT=8000
PYTHON_VERSION=3.11
