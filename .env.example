# Production Environment Variables Template
# Copy this to .env and fill in your values

# Database Configuration
DATABASE_URL=postgresql://postgres:password@postgres.railway.app:5432/railway

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Configuration (Groq recommended - cheaper & faster, OpenAI fallback)
# Get Groq API key free at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-key-here

# OpenAI fallback (optional)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Application Configuration
DEBUG=false
ENVIRONMENT=production

# Frontend Configuration
NEXT_PUBLIC_API_URL=https://your-app-name.railway.app
PUBLIC_URL=https://your-app-name.railway.app

# Security Configuration
CORS_ORIGINS=https://your-app-name.railway.app,https://www.your-app-name.railway.app

# Railway Configuration (auto-set by Railway)
PORT=8000
PYTHON_VERSION=3.11
